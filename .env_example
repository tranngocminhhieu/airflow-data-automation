# ============================================================
# Airflow - Environment Variables (TEMPLATE)
# Copy this file to .env and fill in real values.
# IMPORTANT: never commit the real .env to version control.
# ============================================================

# --- Airflow version (single source: used for both the image and pip install in the venv) ---
AIRFLOW_VERSION=3.2.2

# --- User ID (run: echo $(id -u) to get your UID) ---
AIRFLOW_UID=50000

# --- Project directory (all volumes are relative to this) ---
AIRFLOW_PROJ_DIR=.

# --- Fernet key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())") ---
# Airflow needs a valid Fernet key to encrypt passwords when storing connections
FERNET_KEY=REPLACE_WITH_FERNET_KEY

# --- JWT Auth ---
AIRFLOW__API_AUTH__JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# --- Postgres credentials ---
POSTGRES_USER=REPLACE_WITH_DB_USER
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=airflow

# --- Airflow web admin (created on first init) ---
_AIRFLOW_WWW_USER_USERNAME=REPLACE_WITH_ADMIN_USERNAME
_AIRFLOW_WWW_USER_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD


# --- Airflow Test Connection in Admin > Connections ---
AIRFLOW__CORE__TEST_CONNECTION=Enabled


# --- Task management ---
# Total number of tasks running concurrently across the scheduler (default: 32)
AIRFLOW__CORE__PARALLELISM=32

# Maximum number of active tasks per DAG (default: 16)
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=16

# Maximum number of active DAG runs per DAG (default: 16)
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=16


# --- Reverse proxy (Traefik) — OFF by default; stack deploys standalone on 127.0.0.1:8080 ---
# To route a public domain: set AIRFLOW_HOST here AND uncomment the Traefik blocks in
# docker-compose.yaml (on airflow-apiserver + the proxy_net network at the bottom).
#AIRFLOW_HOST=airflow.example.com


# --- Extra DAG folders (optional): each is registered as its own DAG bundle ---
# Use these when DAG files live in separate folders on the host. Leave commented if unused.
# The primary dags folder (./dags) is the default "dags-folder" bundle and needs no config here.
#DAGS_FOLDER_2=/Users/me/another-folder/dags   # bundle "dags-folder-2"
#DAGS_FOLDER_3=/Users/me/third-folder/dags     # bundle "dags-folder-3"

# --- Git DAG bundles (SSH) — OFF by default; two independent slots: git-1, git-2 ---
# Per slot, uncomment GIT_REPO_URL_n (+ GIT_SSH_KEY_n) to enable. A git bundle is added only when its
# GIT_REPO_URL_n is set, so leaving these commented means no git bundle and no errors.
#   GIT_REPO_URL_n     : SSH URL of the repo
#   GIT_TRACKING_REF_n : branch/tag to track (default: main)
#   GIT_SUBDIR_n           : folder inside the repo holding the DAGs (default: dags)
#   GIT_SSH_KEY_n          : host path to the SSH private key (mounted read-only)
#   GIT_REFRESH_INTERVAL_n : seconds between repo pulls (default: 60)

# Git bundle slot 1 -> bundle "git-1"
#GIT_REPO_URL_1=git@github.com:your-org/repo-a.git
#GIT_TRACKING_REF_1=main
#GIT_SUBDIR_1=dags
#GIT_SSH_KEY_1=/Users/me/.ssh/id_ed25519_a
#GIT_REFRESH_INTERVAL_1=60

# Git bundle slot 2 -> bundle "git-2"
#GIT_REPO_URL_2=git@github.com:your-org/repo-b.git
#GIT_TRACKING_REF_2=main
#GIT_SUBDIR_2=dags
#GIT_SSH_KEY_2=/Users/me/.ssh/id_ed25519_b
#GIT_REFRESH_INTERVAL_2=60